---
import { REPO_URL, LICENSE, KIMCHI_URL, KIMCHI_LOGO } from '../site';
---

<footer class="relative mt-32 overflow-hidden px-6">
  <div class="mx-auto flex max-w-6xl flex-col items-center pb-14">
    <div class="flex items-center gap-2.5">
      <img src="/opener.png" alt="" class="size-7 rounded-lg" />
      <span class="text-base font-semibold tracking-tight">Wopener</span>
    </div>

    <div class="mt-6 flex items-center gap-5 text-sm text-ink-900/55">
      <a href="/faq" class="transition hover:text-ink-900">FAQ</a>
      <a href="/download" class="transition hover:text-ink-900">Download</a>
      <a
        href={REPO_URL}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-1.5 transition hover:text-ink-900"
      >
        <svg viewBox="0 0 24 24" fill="currentColor" class="size-4" aria-hidden="true">
          <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z" />
        </svg>
        GitHub
      </a>
    </div>

    <a
      href="https://www.producthunt.com/products/wopener?embed=true&utm_source=badge-featured&utm_medium=badge&utm_campaign=badge-wopener"
      target="_blank"
      rel="noopener noreferrer"
      class="mt-6 inline-block transition hover:opacity-80"
    >
      <img
        src="https://api.producthunt.com/widgets/embed-image/v1/featured.svg?post_id=1174122&theme=dark&t=1781761684684"
        alt="Wopener - A Web Opener Apple Forgot. | Product Hunt"
        width="250"
        height="54"
      />
    </a>

    <a
      href={KIMCHI_URL}
      target="_blank"
      rel="noopener noreferrer"
      class="mt-6 inline-flex items-center gap-2 text-xs text-ink-900/45 transition hover:text-ink-900"
    >
      <span>Sponsored by</span>
      <img src={KIMCHI_LOGO} alt="Kimchi" class="h-4 w-auto" />
    </a>

    <p class="mt-4 text-xs text-ink-900/35">
      Built by xkaper with 💙
    </p>
  </div>

  <!-- Giant cool wordmark, fading into the floor. -->
  <span
    class="pointer-events-none block bg-gradient-to-b from-black/[0.06] to-transparent bg-clip-text text-center text-[22vw] font-black leading-[0.8] tracking-tighter text-transparent select-none"
    aria-hidden="true"
  >
    Wopener
  </span>
</footer>
