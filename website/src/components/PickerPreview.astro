---
/*
  Interactive in-page replica of the Wopener picker — laid out to mirror the real
  macOS overlay 1:1: the selected browser's name on top, a single horizontal glass
  card (a leading "Save for later" tile, a divider, then numbered browser tiles
  with profile badges), and a detached glass URL chip below.

  The glass is real refraction, not backdrop-filter: liquidGL (public/scripts)
  renders a WebGL lens that refracts the background.jpg filling the framed backdrop.
  Each lens is a dedicated empty `.pp-lens` layer — liquidGL drives the *target's*
  opacity/background, so the tiles and text live in sibling layers ABOVE the lens
  (higher z-index than the fixed refraction canvas) and stay crisp.

  Browser icons auto-load from src/browsers/*.svg — drop a file in there
  (e.g. `arc.svg`, `google-chrome.svg`) and it appears as a tile, named from the
  filename and numbered in A-Z order. With no icons, monogram placeholders render.
*/

const iconUrls = import.meta.glob('../browsers/*.svg', {
  eager: true,
  query: '?url',
  import: 'default',
}) as Record<string, string>;

const niceName = (path: string) =>
  path
    .split('/')
    .pop()!
    .replace(/\.svg$/, '')
    .replace(/[-_]+/g, ' ')
    .replace(/\b\w/g, (c) => c.toUpperCase());

type Tile = { name: string; url?: string };

const fromFolder: Tile[] = Object.entries(iconUrls)
  .map(([path, url]) => ({ name: niceName(path), url }))
  .sort((a, b) => a.name.localeCompare(b.name));

// Placeholders until real icons land — keeps the preview tactile out of the box.
const placeholders: Tile[] = [
  { name: 'Safari' },
  { name: 'Chrome' },
  { name: 'Arc' },
  { name: 'Firefox' },
  { name: 'Brave' },
  { name: 'Edge' },
];

const tiles = (fromFolder.length ? fromFolder : placeholders).slice(0, 9);

// Demo per-profile badges, echoing the real picker's Chromium profile tiles.
const profileBadges: Record<string, string> = {
  'Google Chrome': 'P',
  Brave: 'L',
};

const SAMPLE_URL = 'https://github.com/xkaper001/wopener';
const SAVE_KEY = '`';
const mono = (name: string) => name.trim().charAt(0).toUpperCase();
// Deterministic placeholder gradient per name.
const hue = (name: string) =>
  [...name].reduce((h, c) => (h * 31 + c.charCodeAt(0)) % 360, 7);
---

<!-- Framed backdrop: background.jpg fills it, the picker sits dead-center. -->
<div
  id="pickerPreview"
  class="relative overflow-hidden rounded-[28px]"
  data-sample-url={SAMPLE_URL}
>
  <div class="pp-bg" aria-hidden="true"></div>
  <!-- dimmed-screen wash, matching the real overlay's 0.28 black scrim -->
  <div class="pp-scrim" aria-hidden="true"></div>

  <div
    class="pp-stage relative grid min-h-[440px] place-items-center px-6 py-12"
    tabindex="0"
    role="group"
    aria-label="Interactive Wopener picker preview"
  >
    <div class="pp-cluster flex flex-col items-center gap-2.5">
      <!-- selected browser name -->
      <p id="previewName" class="h-[14px] text-[11px] font-medium text-[#FFF0DF]/70"></p>

      <!-- glass card: refraction lens + (above it) save tile · divider · browser tiles -->
      <div id="previewCard" class="pp-card relative flex items-stretch gap-1 rounded-[20px] p-2.5">
        <div class="pp-glass pp-lens pp-lens-card" aria-hidden="true"></div>
        <div class="pp-tint pp-tint-card" aria-hidden="true"></div>

        <!-- Save for later tile -->
        <button type="button" id="previewSave" class="pp-tile pp-save" aria-label="Save for later" title="Save for later">
          <span class="pp-tile-icon pp-save-icon">
            <svg class="pp-save-bookmark" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M6.5 3h11A1.5 1.5 0 0 1 19 4.5v16.2a.6.6 0 0 1-.93.5L12 17.4l-6.07 3.8a.6.6 0 0 1-.93-.5V4.5A1.5 1.5 0 0 1 6.5 3Z" />
            </svg>
            <svg class="pp-save-check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M5 13l4 4L19 7" />
            </svg>
          </span>
          <span class="pp-hint">{SAVE_KEY}</span>
        </button>

        <span class="pp-divider" aria-hidden="true"></span>

        {tiles.map((t, i) => (
          <button
            type="button"
            class="pp-tile preview-tile"
            data-index={i}
            data-name={t.name}
            aria-label={`Open in ${t.name}`}
          >
            <span class="pp-tile-icon">
              {t.url ? (
                <img src={t.url} alt="" class="size-full object-contain" />
              ) : (
                <span
                  class="grid size-full place-items-center rounded-[13px] text-lg font-bold text-[#FFF0DF]"
                  style={`background: linear-gradient(150deg, hsl(${hue(t.name)} 80% 58%), hsl(${(hue(t.name) + 40) % 360} 75% 46%));`}
                >{mono(t.name)}</span>
              )}
              {profileBadges[t.name] && (
                <span class="pp-profile">{profileBadges[t.name]}</span>
              )}
            </span>
            <span class="pp-hint">{i + 1}</span>
          </button>
        ))}
      </div>

      <!-- detached glass URL chip — click to copy -->
      <button type="button" id="previewChip" class="pp-chip relative" title="Copy link">
        <span class="pp-glass pp-lens pp-lens-chip" aria-hidden="true"></span>
        <span class="pp-tint pp-tint-chip" aria-hidden="true"></span>
        <svg id="previewChipIcon" class="pp-chip-icon size-3.5 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M10 13a5 5 0 0 0 7.07 0l3-3a5 5 0 0 0-7.07-7.07l-1.5 1.5" />
          <path d="M14 11a5 5 0 0 0-7.07 0l-3 3a5 5 0 0 0 7.07 7.07l1.5-1.5" />
        </svg>
        <span id="previewChipLabel" class="pp-chip-label truncate font-medium">github.com/xkaper001/wopener</span>
      </button>
    </div>
  </div>
</div>

<style>
  /*
    Stacking plan (all flatten to the root context — no ancestor here sets a
    z-index/transform/filter — so liquidGL's body-level refraction canvas, which
    it parks at z = lensZ - 1, slots cleanly between the backdrop and the content):
      backdrop .pp-bg ........ z 0
      scrim .pp-scrim ........ z 1
      [liquidGL canvas] ...... z 4   (lensZ - 1) — refracts the backdrop
      lens .pp-lens .......... z 5   (liquidGL target; its bg is stripped)
      tint .pp-tint .......... z 6   (the visible dock fill + border + highlight)
      content (tiles/text) ... z 10
  */
  #pickerPreview .pp-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    background: url('/background.jpg') center / cover no-repeat;
  }
  #pickerPreview .pp-scrim {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: rgb(0 0 0 / 0.28);
    pointer-events: none;
  }

  /*
    The lens layer. liquidGL strips its background and animates its opacity, so it
    holds NO content — only the glass edge (border + inset highlight + drop shadow).
  */
  /* liquidGL target: refraction only. Its background/border get stripped by the
     library, so the visible fill + edge live on the .pp-tint layer above it. */
  #pickerPreview .pp-lens {
    position: absolute;
    inset: 0;
    z-index: 5;
    pointer-events: none;
  }
  .pp-lens-card { border-radius: 20px; }
  .pp-lens-chip { border-radius: 9999px; }

  /* The visible glass dock: a single rounded wrapper enclosing the whole row,
     sitting above the refraction canvas so it tints the refracted backdrop. */
  #pickerPreview .pp-tint {
    position: absolute;
    inset: 0;
    z-index: 6;
    pointer-events: none;
  }
  .pp-tint-card {
    border-radius: 20px;
    /* neutral frost — the glass takes its colour from the backdrop behind it */
    background: rgb(255 240 223 / 0.12);
    border: 1px solid rgb(255 240 223 / 0.28);
    box-shadow:
      inset 0 1px 0 rgb(255 240 223 / 0.45),
      inset 0 0 0 1px rgb(255 240 223 / 0.06),
      0 20px 55px rgb(0 0 0 / 0.4);
  }
  .pp-tint-chip {
    border-radius: 9999px;
    background: rgb(255 240 223 / 0.14);
    border: 1px solid rgb(255 240 223 / 0.22);
    box-shadow: inset 0 1px 0 rgb(255 240 223 / 0.35);
  }

  /* Card is a transparent layout shell; the lens behind it is the glass. */
  .pp-card { background: transparent; }

  .pp-chip {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    max-width: min(100%, 360px);
    padding: 6px 14px;
    border-radius: 9999px;
    font-size: 13px;
    color: rgb(255 240 223 / 0.92);
    transition: transform 0.18s var(--ease-spring);
  }
  .pp-chip:active { transform: scale(0.97); }
  .pp-chip-icon { position: relative; z-index: 10; color: rgb(255 240 223 / 0.6); }
  .pp-chip-label { position: relative; z-index: 10; }

  /* Tiles sit above the refraction canvas; only selection tints them. */
  .pp-tile {
    position: relative;
    z-index: 10;
    pointer-events: auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
    padding: 4px;
    border-radius: 14px;
    outline: none;
    background: transparent;
    transition:
      background 0.18s var(--ease-out),
      box-shadow 0.18s var(--ease-out);
  }
  .pp-tile-icon {
    position: relative;
    display: grid;
    place-items: center;
    width: 46px;
    height: 46px;
  }
  .pp-tile-icon > img,
  .pp-tile-icon > .grid {
    transition: transform 0.2s var(--ease-spring);
  }
  .pp-hint {
    font:
      600 11px / 1 ui-rounded,
      var(--font-sans);
    color: rgb(255 240 223 / 0.55);
  }

  /* Selection: the same white wash + hairline ring the app draws. */
  .preview-tile.is-selected {
    background: rgb(255 240 223 / 0.18);
    box-shadow: inset 0 0 0 1px rgb(255 240 223 / 0.5);
  }
  /* Click feedback only — no enlarge on hover/selection. */
  .preview-tile.is-opening .pp-tile-icon > img,
  .preview-tile.is-opening .pp-tile-icon > .grid {
    animation: tile-pop 0.4s var(--ease-spring);
  }
  @keyframes tile-pop {
    0% { transform: scale(1); }
    50% { transform: scale(0.92); }
    100% { transform: scale(1); }
  }

  /* Leading Save tile reads as a light frosted square, like the app. */
  .pp-save-icon {
    border-radius: 14px;
    background: rgb(255 240 223 / 0.9);
    box-shadow: inset 0 1px 0 rgb(255 240 223 / 0.9);
  }
  .pp-save-icon {
    position: relative;
    overflow: hidden;
  }
  .pp-save-icon svg {
    position: absolute;
    inset: 0;
    margin: auto;
    width: 22px;
    height: 22px;
    transition:
      transform 0.3s var(--ease-spring),
      opacity 0.25s var(--ease-out);
  }
  .pp-save-bookmark {
    color: #1a1f29;
  }
  /* Hidden until save fires; green draws in as the bookmark morphs out. */
  .pp-save-check {
    color: #16a34a;
    opacity: 0;
    transform: scale(0.4);
    stroke-dasharray: 22;
    stroke-dashoffset: 22;
  }
  .pp-save.is-saved .pp-save-icon {
    animation: save-pop 0.45s var(--ease-spring);
  }
  .pp-save.is-saved .pp-save-bookmark {
    opacity: 0;
    transform: scale(0.5);
  }
  .pp-save.is-saved .pp-save-check {
    opacity: 1;
    transform: scale(1);
    animation: save-check-draw 0.4s var(--ease-out) 0.06s forwards;
  }
  @keyframes save-pop {
    0% { transform: scale(1); }
    35% { transform: scale(0.86); }
    70% { transform: scale(1.1); }
    100% { transform: scale(1); }
  }
  @keyframes save-check-draw {
    to { stroke-dashoffset: 0; }
  }

  /* Green per-profile badge, bottom-trailing on the icon. */
  .pp-profile {
    position: absolute;
    right: -2px;
    bottom: -2px;
    display: grid;
    place-items: center;
    width: 17px;
    height: 17px;
    border-radius: 9999px;
    border: 2px solid rgb(255 240 223 / 0.9);
    background: linear-gradient(160deg, #4ade80, #16a34a);
    color: #FFF0DF;
    font: 700 11px / 1 var(--font-sans);
    box-shadow: 0 1px 4px rgb(0 0 0 / 0.3);
  }

  .pp-divider {
    position: relative;
    z-index: 10;
    align-self: center;
    width: 1px;
    height: 46px;
    margin: 0 4px;
    background: rgb(255 240 223 / 0.18);
  }

  .pp-stage:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: -4px;
    border-radius: 28px;
  }

  @media (prefers-reduced-motion: reduce) {
    .pp-tile-icon > img,
    .pp-tile-icon > .grid { transition: none; animation: none; }
    .pp-save-icon svg,
    .pp-save.is-saved .pp-save-icon { transition: none; animation: none; }
    .pp-save.is-saved .pp-save-check { stroke-dashoffset: 0; }
  }
</style>

<!-- liquidGL: real WebGL glass refraction over the framed background. -->
<script is:inline src="/scripts/html2canvas.min.js"></script>
<script is:inline src="/scripts/liquidGL.js"></script>
<script is:inline>
  function initPickerGlass() {
    if (typeof window.liquidGL !== 'function') return;
    const frame = document.getElementById('pickerPreview');
    if (!frame || frame.dataset.glassReady) return;
    frame.dataset.glassReady = '1';
    window.liquidGL({
      target: '#pickerPreview .pp-lens',
      snapshot: '#pickerPreview',
      resolution: 2,
      refraction: 0.045,
      bevelDepth: 0.12,
      bevelWidth: 0.2,
      frost: 2,
      specular: true,
      shadow: false,
      reveal: 'fade',
    });
  }
  if (document.readyState === 'complete') initPickerGlass();
  else window.addEventListener('load', initPickerGlass);
</script>

<script>
  const root = document.getElementById('pickerPreview');
  const stage = root?.querySelector<HTMLElement>('.pp-stage');
  if (root && stage) {
    const tiles = Array.from(root.querySelectorAll<HTMLButtonElement>('.preview-tile'));
    const nameEl = root.querySelector<HTMLElement>('#previewName')!;
    const chip = root.querySelector<HTMLButtonElement>('#previewChip')!;
    const chipLabel = root.querySelector<HTMLElement>('#previewChipLabel')!;
    const chipIcon = root.querySelector<SVGElement>('#previewChipIcon')!;
    const saveBtn = root.querySelector<HTMLButtonElement>('#previewSave')!;
    const sampleUrl = root.dataset.sampleUrl || '';
    const sampleLabel = chipLabel.textContent || sampleUrl;
    let selected = 0; // first browser highlighted on entry, mirroring the app.
    let chipTimer: number | undefined;

    const select = (i: number) => {
      selected = (i + tiles.length) % tiles.length;
      tiles.forEach((t, n) => t.classList.toggle('is-selected', n === selected));
      nameEl.textContent = tiles[selected]?.dataset.name || '';
    };

    const open = (i: number) => {
      const tile = tiles[i];
      if (!tile) return;
      select(i);
      tile.classList.remove('is-opening');
      void tile.offsetWidth; // restart animation
      tile.classList.add('is-opening');
      window.setTimeout(() => tile.classList.remove('is-opening'), 520);
    };

    select(0);

    tiles.forEach((tile, i) => {
      tile.addEventListener('mouseenter', () => select(i));
      tile.addEventListener('click', () => { stage.focus(); open(i); });
    });

    let saveTimer: number | undefined;
    saveBtn.addEventListener('click', () => {
      saveBtn.classList.remove('is-saved');
      void saveBtn.offsetWidth; // restart the morph + pop
      saveBtn.classList.add('is-saved');
      window.clearTimeout(saveTimer);
      saveTimer = window.setTimeout(() => saveBtn.classList.remove('is-saved'), 1500);
    });

    const flashCopied = () => {
      chipLabel.textContent = 'Copied';
      chipIcon.innerHTML = '<path d="M5 13l4 4L19 7" />';
      window.clearTimeout(chipTimer);
      chipTimer = window.setTimeout(() => {
        chipLabel.textContent = sampleLabel;
        chipIcon.innerHTML =
          '<path d="M10 13a5 5 0 0 0 7.07 0l3-3a5 5 0 0 0-7.07-7.07l-1.5 1.5" />' +
          '<path d="M14 11a5 5 0 0 0-7.07 0l-3 3a5 5 0 0 0 7.07 7.07l1.5-1.5" />';
      }, 1600);
    };
    chip.addEventListener('click', async () => {
      try { await navigator.clipboard.writeText(sampleUrl); } catch { /* clipboard may be blocked */ }
      flashCopied();
    });

    stage.addEventListener('keydown', (e) => {
      if (e.key === sampleUrl) return;
      if (e.key === '`') { e.preventDefault(); saveBtn.click(); return; }
      if (e.key >= '1' && e.key <= '9') {
        const i = Number(e.key) - 1;
        if (i < tiles.length) { e.preventDefault(); open(i); }
      } else if (e.key === 'ArrowRight' || e.key === 'ArrowDown') {
        e.preventDefault(); select(selected + 1);
      } else if (e.key === 'ArrowLeft' || e.key === 'ArrowUp') {
        e.preventDefault(); select(selected - 1);
      } else if (e.key === 'Enter') {
        e.preventDefault(); open(selected);
      }
    });
  }
</script>
