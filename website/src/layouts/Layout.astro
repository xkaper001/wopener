---
import '../styles/global.css';

interface Props {
  title?: string;
}

const { title = 'Wopener' } = Astro.props;
const pageTitle = title === 'Wopener' ? 'Wopener - Your link, your choice' : `${title} - Wopener`;
const description = 'A macOS default-browser interceptor. Click any link and a Liquid Glass picker lets you choose which browser opens it.';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content="/opener.png" />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <title>{pageTitle}</title>
  </head>
  <body class="font-sans text-ink-900 antialiased selection:bg-accent/30">
    <div class="flex min-h-[100dvh] flex-col overflow-x-clip">
      <slot />
    </div>
  </body>
</html>
