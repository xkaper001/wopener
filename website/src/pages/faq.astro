---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { MIN_MACOS, LICENSE, REPO_URL } from '../site';

const faqs = [
  {
    q: 'What is Wopener?',
    a: 'A macOS default-browser interceptor. Set it as your default browser and clicking any link shows a glass picker so you choose which real browser opens it.',
  },
  {
    q: 'How do I set Wopener as my default browser?',
    a: 'Open Wopener, go to the Browsers tab, and click Set as Default Browser. That surfaces the standard macOS confirmation dialog. You can also set it in System Settings, Desktop and Dock, Default web browser.',
  },
  {
    q: 'Does it support per-browser profiles?',
    a: 'Yes. Chromium-family browsers like Chrome, Brave, Edge, Vivaldi and Opera expand into one tile per profile, with the signed-in account photo shown as a badge. Safari profiles are not supported, since there is no public API to open a specific one.',
  },
  {
    q: 'Can I save links for later?',
    a: 'Yes. Press the save key (backtick by default) in the picker to stash a link in the Saved tab instead of opening it. Reopen the picker for it anytime.',
  },
  {
    q: 'Does Wopener remember my choices or auto-route links?',
    a: 'No, and that is intentional. It never silently picks for you. The only persisted state is your browser order, toggles, saved links, and picker preferences.',
  },
  {
    q: 'What are the system requirements?',
    a: `${MIN_MACOS} or later. Wopener is built with Swift and SwiftUI using Apple's Liquid Glass effects.`,
  },
  {
    q: 'Why does macOS say it cannot verify the developer?',
    a: 'Wopener is not signed or notarized yet, so Gatekeeper blocks it on first launch. Right-click (or Control-click) the app, choose Open, then Open again in the dialog. Alternatively, open it once, then go to System Settings, Privacy and Security, and click Open Anyway. You only do this once.',
  },
  {
    q: 'Is it open source?',
    a: `Yes. Wopener is licensed under ${LICENSE}. The source lives on GitHub at ${REPO_URL.replace('https://', '')}.`,
  },
];
---

<Layout title="FAQ">
  <Header currentPath="/faq" />

  <main class="flex flex-1 flex-col items-center px-5">
    <section class="w-full max-w-2xl pt-32 text-center sm:pt-40">
      <h1 class="text-4xl font-bold tracking-tight sm:text-6xl">Questions</h1>
      <p class="mt-5 text-lg text-ink-900/60">Everything worth knowing about Wopener.</p>
    </section>

    <section class="mt-12 w-full max-w-2xl">
      <div class="divide-y divide-black/10 border-y border-black/10">
        {faqs.map((item) => (
          <details class="group">
            <summary class="flex cursor-pointer list-none items-center justify-between gap-4 px-6 py-5 text-base font-semibold sm:text-lg">
              {item.q}
              <svg
                class="size-5 shrink-0 text-ink-900/45 transition duration-300 group-open:rotate-180"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2"
                aria-hidden="true"
              >
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <p class="px-6 pb-6 leading-relaxed text-ink-900/60">{item.a}</p>
          </details>
        ))}
      </div>
    </section>
  </main>

  <Footer />
</Layout>
