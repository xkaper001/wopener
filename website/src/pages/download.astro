---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CTAButton from '../components/CTAButton.astro';
import { RELEASES_URL, REPO_URL, MIN_MACOS, LICENSE } from '../site';

const steps = [
  'Open Wopener from your Applications folder.',
  'In the Browsers tab, click Set as Default Browser.',
  'Confirm in the macOS dialog that appears.',
  'Click any link. The picker appears.',
];

// First-launch Gatekeeper walkthrough. Drop the screenshots into
// website/public/ at these paths and they appear automatically.
const gatekeeperSteps = [
  {
    title: 'Right-click and choose Open',
    body:
      'Double-clicking shows a dead-end "can’t be opened" alert. Instead, right-click (or Control-click) Wopener in your Applications folder and choose Open.',
    img: '/gatekeeper-open.avif',
    alt: 'Right-clicking Wopener in the Applications folder and choosing Open from the context menu.',
  },
  {
    title: 'Click Open in the dialog',
    body:
      'The same warning appears, but this time with an Open button. Click it once — macOS remembers your choice and never asks again.',
    img: '/gatekeeper-dialog.avif',
    alt: 'The macOS Gatekeeper dialog with an Open button that launches Wopener.',
  },
];
---

<Layout title="Download">
  <Header currentPath="/download" />

  <main class="flex flex-1 flex-col items-center px-5">
    <section class="w-full max-w-3xl pt-32 text-center sm:pt-40">
      <h1 class="text-4xl font-bold tracking-tight sm:text-6xl">Download Wopener</h1>
      <p class="mx-auto mt-5 max-w-md text-lg text-ink-900/60">
        Free and {LICENSE} licensed. Grab the latest build, or compile it
        yourself.
      </p>
      <div class="mt-9 flex flex-col items-center justify-center gap-3 sm:flex-row">
        <CTAButton href="/download/thanks" label="Download for Mac" />
        <CTAButton href={RELEASES_URL} variant="secondary" label="All releases" />
      </div>
      <p class="mt-4 text-sm text-ink-900/40">
        {MIN_MACOS} or later. Not yet notarized, so macOS blocks it on first
        launch — the one-time fix is right below.
        <a href="/#notarisation" class="underline underline-offset-2 hover:text-ink-900/70">Kimchi's funding it.</a>
      </p>
    </section>

    <!-- First launch / Gatekeeper -->
    <section class="w-full max-w-3xl pt-20 sm:pt-24">
      <h2 class="text-2xl font-bold tracking-tight sm:text-3xl">First launch on macOS</h2>
      <p class="mt-3 max-w-xl text-ink-900/55">
        Wopener isn’t notarized yet (that costs $99/yr from Apple), so Gatekeeper
        steps in the first time you open it. <a href="/#notarisation" class="underline underline-offset-2 hover:text-ink-900/70">Kimchi sponsored the Apple Developer Program</a>,
        so notarized builds are on the way — until they ship, this is a one-time
        dance: do it once and macOS never bothers you again.
      </p>

      <div class="mt-8 grid gap-6 sm:grid-cols-2">
        {gatekeeperSteps.map((s, i) => (
          <figure class="flex flex-col overflow-hidden rounded-2xl border border-black/10">
            <img
              src={s.img}
              alt={s.alt}
              class="aspect-[4/3] w-full bg-black/[0.03] object-cover"
              loading="lazy"
              decoding="async"
            />
            <figcaption class="flex flex-1 flex-col gap-1.5 p-5">
              <div class="flex items-center gap-3">
                <span class="grid size-7 shrink-0 place-items-center rounded-full bg-accent text-xs font-bold text-[#FFF0DF]">
                  {i + 1}
                </span>
                <span class="font-semibold">{s.title}</span>
              </div>
              <p class="text-sm leading-snug text-ink-900/60">{s.body}</p>
            </figcaption>
          </figure>
        ))}
      </div>

      <div class="mt-6 rounded-2xl border border-black/10 bg-black/[0.02] p-5 text-sm text-ink-900/65">
        <p class="font-semibold text-ink-900/80">Prefer System Settings?</p>
        <p class="mt-1">
          Open Wopener once, then go to <span class="font-medium">System Settings ▸ Privacy &amp; Security</span>
          and click <span class="font-medium">Open Anyway</span>. Or, from a terminal:
        </p>
        <pre class="mt-3 overflow-x-auto rounded-xl border border-[#FFF0DF]/10 bg-ink-950 px-4 py-3 font-mono text-xs text-[#FFF0DF]/85"><code>xattr -dr com.apple.quarantine /Applications/Wopener.app</code></pre>
        <img
          src="/gatekeeper-3.avif"
          alt="System Settings ▸ Privacy & Security showing the Open Anyway button for Wopener."
          class="mt-4 w-full rounded-xl border border-black/10"
          loading="lazy"
          decoding="async"
        />
      </div>
    </section>

    <!-- Build from source -->
    <section class="w-full max-w-3xl pt-20 sm:pt-24">
      <div>
        <h2 class="text-xl font-semibold">Build from source</h2>
        <p class="mt-2 text-ink-900/55">Requires {MIN_MACOS} and Xcode 26 or later.</p>
        <pre class="mt-5 overflow-x-auto rounded-2xl border border-[#FFF0DF]/10 bg-ink-950 p-5 font-mono text-sm leading-relaxed text-[#FFF0DF]/85"><code>git clone {REPO_URL}.git
cd wopener
xcodebuild -project Wopener.xcodeproj -scheme Wopener \
  -configuration Debug build</code></pre>
      </div>
    </section>

    <!-- Setup steps -->
    <section class="w-full max-w-3xl pt-20 sm:pt-24">
      <h2 class="text-2xl font-bold tracking-tight sm:text-3xl">Set it up in seconds</h2>
      <ol class="mt-7 space-y-3">
        {steps.map((step, i) => (
          <li class="flex items-center gap-4 rounded-2xl border border-black/10 px-5 py-4">
            <span class="grid size-9 shrink-0 place-items-center rounded-full bg-accent text-sm font-bold text-[#FFF0DF]">
              {i + 1}
            </span>
            <span class="text-ink-900/75">{step}</span>
          </li>
        ))}
      </ol>
    </section>
  </main>

  <Footer />
</Layout>
